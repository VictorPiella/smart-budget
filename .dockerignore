# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Node / frontend build artifacts ───────────────────────────────────────────
frontend/node_modules
frontend/build

# ── Python caches ─────────────────────────────────────────────────────────────
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache
.mypy_cache

# ── Local environment & secrets ───────────────────────────────────────────────
.env
.env.*
*.env

# ── Editor / OS junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea
.vscode

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose*.yml
.dockerignore

# ── Test data & docs ──────────────────────────────────────────────────────────
smartbudget-test-data.json
*.md

# ── Telegram bot: models & cache (downloaded at runtime, not baked in) ────────
telegram-bot/__pycache__
telegram-bot/.cache

# ── Uploads volume (handled by Docker volume, not build context) ──────────────
uploads/
