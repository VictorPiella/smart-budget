# ─────────────────────────────────────────────────────────────────────────────
# SmartBudget — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub username (used by docker-compose.prod.yml to pull images)
DOCKER_USER=yourdockerhubusername

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=budget_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=budget_db
# DB_HOST defaults to "db" (docker-compose hostname). Set to an IP when using
# Unraid br0/macvlan where hostname resolution doesn't work, e.g.:
# DB_HOST=192.168.0.231
DB_HOST=db

# ── FastAPI JWT secret ────────────────────────────────────────────────────────
# Generate a strong value with:  openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_secret
