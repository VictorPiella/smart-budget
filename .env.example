# ─────────────────────────────────────────────────────────────────────────────
# SmartBudget — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub username (used by docker-compose.prod.yml to pull the image)
DOCKER_USER=yourdockerhubusername

# ── PostgreSQL (runs inside the app container) ────────────────────────────────
POSTGRES_USER=budget_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=budget_db

# ── FastAPI JWT secret ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_secret

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Leave blank to disable the bot entirely (no restart loop — clean exit).
# Get BOT_TOKEN from @BotFather on Telegram.
# Each user authenticates individually inside the bot via /login — no shared
# credentials needed here.
BOT_TOKEN=

# ── Magic link / forgot password (optional) ───────────────────────────────────
# If SMTP_HOST is blank, magic links are printed to the backend container logs
# instead of emailed — useful for local dev (check: docker logs budget_app).
# For Gmail: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=SmartBudget <your-email@gmail.com>
APP_URL=https://budget.piella.me
